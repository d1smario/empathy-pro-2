{
  "name": "empathy-pro-2",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0 <25.0.0",
    "npm": ">=7.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "tooling/*"
  ],
  "scripts": {
    "postinstall": "patch-package",
    "dev": "node ./scripts/next-dev.mjs",
    "dev:clean": "node ./scripts/clean-next-artifacts.mjs",
    "dev:safe": "node ./scripts/clean-next-artifacts.mjs && node ./scripts/next-dev.mjs",
    "dev:fixed": "node ./node_modules/next/dist/bin/next dev ./apps/web -p 3020",
    "dev:3000": "node ./node_modules/next/dist/bin/next dev ./apps/web -p 3000",
    "build": "node ./node_modules/next/dist/bin/next build ./apps/web",
    "build:clean": "node ./scripts/clean-next-artifacts.mjs && npm run build",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "node ./node_modules/next/dist/bin/next lint ./apps/web",
    "verify": "npm run typecheck && npm run lint && node ./scripts/clean-next-artifacts.mjs && npm run build"
  },
  "devDependencies": {
    "patch-package": "^8.0.1"
  }
}
