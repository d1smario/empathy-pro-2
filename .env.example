# Copiare in apps/web/.env.local (non committare). Valori reali solo in locale / segreti CI.

# Supabase (fase dati)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Stripe (atleta / coach / SKU — vedi docs/COMMERCIAL_AND_ROLES.md)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# LogMeal — diario alimentare AI (solo server-side). Vedi docs/INTEGRATIONS_LOGMEAL.md
# LOGMEAL_API_KEY=
# LOGMEAL_API_BASE_URL=

# Spline — scene 3D esercizi (spesso URL pubblici; eventuali segreti solo se richiesti dal piano)
# Vedi docs/INTEGRATIONS_SPLINE.md
# SPLINE_SCENE_BASE_URL=
# NEXT_PUBLIC_SPLINE_*  (solo se la runtime lo richiede — verificare doc Spline)
