# Copiare in apps/web/.env.local (non committare). Valori reali solo in locale / segreti CI.
#
# Vercel / produzione: `npm run build` (root) non imposta NEXT_DIST_DIR → Next scrive in apps/web/.next
# (come da next.config). Le cartelle apps/.empathy-pro2-next-dev e script Windows valgono solo per `npm run dev` locale.
#
# Dev Windows: `npm run dev` → apps/.empathy-pro2-next-dev — dettagli in apps/web/.env.example

# Supabase (fase dati)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role (solo server): necessario per import/training write affidabili con RLS — copia da Supabase Dashboard → Settings → API. Non esporre al client. Vedi `apps/web/lib/supabase/admin.ts`.
# SUPABASE_SERVICE_ROLE_KEY=

# Stripe — stessi nomi di V1 (`nextjs-empathy-pro/.env.example`)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_PRICE_SILVER_EUR=price_...
# STRIPE_PRICE_GOLD_EUR=price_...
# STRIPE_PRICE_COACH_ELITE_EUR=price_...
# STRIPE_PRICE_COACH_PRO_EUR=price_...
# STRIPE_PRICE_COACH_OLIMPIC_EUR=price_...
# NEXT_PUBLIC_STRIPE_CHECKOUT_SUCCESS_PATH=/settings?billing=success
# NEXT_PUBLIC_STRIPE_CHECKOUT_CANCEL_PATH=/settings?billing=cancel
# Opzionale Pro 2 web: NEXT_PUBLIC_STRIPE_PAYMENT_LINK=https://buy.stripe.com/...
# Demo checkout Silver/Gold senza auth: STRIPE_CHECKOUT_ANON_ENABLED=1
# STRIPE_CHECKOUT_TRIAL_DAYS=15

# LogMeal — diario alimentare AI (solo server-side). Vedi docs/INTEGRATIONS_LOGMEAL.md
# LOGMEAL_API_KEY=
# LOGMEAL_API_BASE_URL=

# Spline — scene 3D esercizi (spesso URL pubblici; eventuali segreti solo se richiesti dal piano)
# Vedi docs/INTEGRATIONS_SPLINE.md
# SPLINE_SCENE_BASE_URL=
# NEXT_PUBLIC_SPLINE_*  (solo se la runtime lo richiede — verificare doc Spline)
