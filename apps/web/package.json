    "@empathy/domain-physiology": "0.1.0",
    "@empathy/domain-reality": "0.1.0",
    "@empathy/domain-training": "0.1.0",
    "@empathy/domain-twin": "0.1.0",
    "@empathy/integrations-logmeal": "0.1.0",
    "@empathy/integrations-spline": "0.1.0",
    "@empathy/integrations-stripe": "0.1.0",
    "@empathy/integrations-supabase": "0.1.0",
    "@supabase/ssr": "^0.5.2",
    "fit-file-parser": "^2.3.3",
    "lucide-react": "^0.468.0",
    "motion": "^11.15.0",
    "next": "14.2.3",
    "oauth-1.0a": "^2.2.6",
    "pdf-parse": "^1.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.0",
    "server-only": "^0.0.1",
    "stripe": "^17.6.0"
  },
